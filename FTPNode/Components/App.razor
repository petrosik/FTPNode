@using Shared
@inject Services.ISharedStorage Storage
@inject AppState State
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["light.css"]" />
    <link rel="stylesheet" href="@Assets["dark.css"]" />
    <link rel="stylesheet" href="@Assets["FTPNode.styles.css"]" />
    @if (Storage.TryGetArg("availablethemestrimmed", out object v) && v is List<string> ll)
    {
        foreach (var item in ll)
        {
            <link rel="stylesheet" href="@Assets[$"{item}.css"]" />
        }
    }
    <ImportMap />
    <link rel="icon" type="@(Storage.TryGetArg("pageicon", out v) ?Utils.GetMimeTypeFromExtension(Path.GetExtension((string)v)): "image/png")" href="favicon@(v!= null  ? $"1{Path.GetExtension((string)v)}" : ".png")" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="@Assets["js/helpers.js"]"></script>
    <HeadOutlet @rendermode="InteractiveWebAssembly" />
    <title>@(Storage.TryGetArg("title", out v)?v:"FTP Node")</title>
</head>

<body data-theme="@(Storage.TryGetArg("defaulttheme", out v)? v:"light")">
    <Routes @rendermode="InteractiveWebAssembly" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>

	public async Task OnKeyDown(KeyInfo key)
	{
		if (State.Selected.Count(x => x != null) <= 0) return;
		if (key.Key == "Delete")
		{
			await JS.InvokeVoidAsync("helpers.clickById", "DeleteConfirm");
		}
		else if (key.Key == "c" && key.Ctrl)
		{

		}
		else if (key.Key == "v" && key.Ctrl)
		{

		}
		else if (key.Key == "ArrowUp" && key.Shift)
		{
			var ordered = CurrentDir.Second.OrderBy(x => x.Type).ThenBy(x => x.Name).ToList();
			var ind = ordered.IndexOf(State.Selected.First(x => x != null));
			var lastind = ordered.IndexOf(State.Selected.Last(x => x != null));

			if (ind == -1 || lastind == -1) return;
			if (lastind == ind && ind > 0)
			{
				State.Selected.Add(ordered.ElementAt(ind - 1));
			}
			else if (lastind > ind)
			{
				State.Selected.RemoveAt(State.Selected.Count - 1);
			}
			else if (lastind < ind && lastind > 0)
			{
				State.Selected.Add(ordered.ElementAt(lastind - 1));
			}
		}
		else if (key.Key == "ArrowDown" && key.Shift)
		{
			var ordered = CurrentDir.Second.OrderBy(x => x.Type).ThenBy(x => x.Name).ToList();
			var ind = ordered.IndexOf(State.Selected.First(x => x != null));
			var lastind = ordered.IndexOf(State.Selected.Last(x => x != null));
			if (ind == -1 || lastind == -1) return;
			if (lastind == ind && ind < ordered.Count)
			{
				State.Selected.Add(ordered.ElementAt(ind + 1));
			}
			else if (lastind > ind && lastind + 1 < ordered.Count)
			{
				State.Selected.Add(ordered.ElementAt(lastind + 1));
			}
			else if (lastind < ind && lastind < ordered.Count)
			{
				State.Selected.RemoveAt(State.Selected.Count - 1);
			}
		}
		else if (key.Key == "ArrowDown")
		{
			var ordered = CurrentDir.Second.OrderBy(x => x.Type).ThenBy(x => x.Name).ToList();
			var ind = ordered.IndexOf(State.Selected.Last(x => x != null));
			if (ind + 1 < ordered.Count)
			{
				State.Selected.Clear();
				State.Selected.Add(ordered.ElementAt(ind + 1));
			}
		}
		else if (key.Key == "ArrowUp")
		{
			var ordered = CurrentDir.Second.OrderBy(x => x.Type).ThenBy(x => x.Name).ToList();
			var ind = ordered.IndexOf(State.Selected.Last(x => x != null));
			if (ind > 0)
			{
				State.Selected.Clear();
				State.Selected.Add(ordered.ElementAt(ind - 1));
			}
		}
		State.NotifyStateChanged();
	}
	public async Task PreventClosing(bool allowed)
	{
		if (allowed)
		{
			await JS.InvokeVoidAsync("helpers.setEnabled", true);
			return;
		}

		bool uploadsRunning = State.UploadQue.Any(x => x.Value.Proggress != 100d);
		bool downloadsRunning = DownloadQue.Any(x => x.Value.Proggress != 100d);

		if (!uploadsRunning && State.UploadQue.Count > 0)
			await JS.InvokeVoidAsync("helpers.showNotification", State.Settings.TryGetValue("title", out var v) ? v : "FTP Node", "Upload has finished");

		if (!downloadsRunning && DownloadQue.Count > 0)
			await JS.InvokeVoidAsync("helpers.showNotification", State.Settings.TryGetValue("title", out var v) ? v : "FTP Node", "Download has finished");

		if (!uploadsRunning && !downloadsRunning)
		{
			await JS.InvokeVoidAsync("helpers.setEnabled", false);
		}
	}
	private async Task OnLogin()
	{
		Error = "";
		Connecting = true;
		if (!State.RememberMe.RememberMe)
		{
			State.RememberMe.Host = null;
			State.RememberMe.Username = null;
			State.RememberMe.Port = 21;
			State.RememberMe.PassiveMode = true;
		}
		else
		{
			State.RememberMe.Host = LoginStuff.Host;
			State.RememberMe.Port = LoginStuff.Port;
			State.RememberMe.Username = LoginStuff.Username;
			State.RememberMe.PassiveMode = LoginStuff.PassiveMode;
		}
		await SaveRememberMe();

		await StartHubConn();
		if (HubGood())
		{
			if (State.Settings.TryGetValue("host", out var host))
				LoginStuff.Host = host;
			if (State.Settings.TryGetValue("port", out var port) && int.TryParse(port, out var pp))
				LoginStuff.Port = pp;
			if (State.Settings.TryGetValue("passivemode", out var pass) && bool.TryParse(pass, out var pas))
				LoginStuff.PassiveMode = pas;


			var cert = await Hub.InvokeAsync<CertificateDto?>("GetCert", LoginStuff.Host, LoginStuff.Port);
			var usecerttrust = State.Settings.TryGetValue("enablecerttrustfunction", out var val) && bool.TryParse(val, out var va) && va;
			var skipcertcheck = false;
			if (usecerttrust)
			{
				try
				{
					var certs = JsonSerializer.Deserialize<List<TrustedCertDto>>(await JS.InvokeAsync<string>("localStorage.getItem", "trustedCerts"));
					skipcertcheck = certs.Any(x => x.Thumbprint == cert.Thumbprint);
					LoginStuff.AcceptCert = true;
					LoginStuff.OriginalCertThumbprint = cert.Thumbprint;
				}
				catch { }
			}
			if (cert != null && !skipcertcheck)
			{
				var tcs = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously);
				CertWindowOpen = true;
				Certificate = cert;
				_certQuestion = tcs;
				StateHasChanged();
				LoginStuff.AcceptCert = await tcs.Task;
				LoginStuff.OriginalCertThumbprint = cert.Thumbprint;
			}
			if (!State.Settings.TryGetValue("publickey", out var pubkey))
			{
				Error = "Public key not set in settings, refusing to connect for security reasons";
				StateHasChanged();
				return;
			}
			//encrypt password with RSA
			string encryptedPassword = await JS.InvokeAsync<string>("helpers.encryptPasswordWithPublicKey", LoginStuff.Password, pubkey);
			LoginStuff.Password = encryptedPassword;

			var res = await Hub.InvokeAsync<string>("InitFtp", LoginStuff);
			if (CheckReturn(res))
			{
				LoggedIn = true;
				GetDirectory(Path);
			}
			else
			{
				LoginStuff.Password = "";
			}
		}
		Connecting = false;
	}

@using System.Net
@using Shared
@using Microsoft.AspNetCore.SignalR.Client;
@using Microsoft.Extensions.Configuration;
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting;
@using System.Text.Json;
@using System.Text
@using FTPNode.Client.Components;
@page "/"
@page "/{*path:nonfile}"
@inject HttpClient Http
@inject IConfiguration Env
@inject IJSRuntime JS
@inject AppState State
@inject NavigationManager Nav
@rendermode InteractiveWebAssembly

<PageTitle>@($"{(State.Settings.TryGetValue("title", out var v) ? v : "FTP Node")}{(CurrDirPath.Count > 0 ? $" - {(CurrDirPath.Count > 1 ? ".." : "")}/{CurrDirPath.Last()}" : "")}")</PageTitle>
<div>
	<InputFile id="fileInput" class="file-input-overlay" OnChange="HandleFileSelected" multiple />
</div>
@if (!LoggedIn)
{
	<OverlayWindow XPercent="95" YPercent="85">
		<h2 style="font-weight:bold; padding:1%; height:auto; margin:0;">Login</h2>
		@if (!Loading)
		{
			<form @onsubmit="OnLogin" style="display:flex;flex-direction:column; align-items:center; gap:2vh; height:auto; margin:2%">
				<div style="display:grid; grid-template-columns:10fr 90fr; align-items:center; gap:1%;">
					@if (!State.Settings.ContainsKey("host"))
					{
						<p style="margin:0">
							Host:
						</p>
						<InputText @bind-value=LoginStuff.Host placeholder="10.0.0.0 or example.com" />
					}
					@if (!State.Settings.ContainsKey("port"))
					{
						<p style="margin:0">
							Port:
						</p>
						<InputNumber @bind-value=LoginStuff.Port placeholder="21" />
					}
					<p style="margin:0">
						Username:
					</p>
					<InputText @bind-value=LoginStuff.Username />
					<p style="margin:0">
						Password:
					</p>
					<InputText @bind-Value="LoginStuff.Password" type="@(ShowPass ? "text" : "password")" />
				</div>
				<div style="display:flex; flex-direction:row; justify-content:space-between; gap:10vw">
					<div style="display:flex; flex-direction:column; justify-content:space-between;gap:2vh">
						<label>
							Remember Me:
							<InputCheckbox @bind-Value=State.RememberMe.RememberMe />
						</label>
						@if (!State.Settings.ContainsKey("passivemode"))
						{
							<label>
								Passive Mode:
								<InputCheckbox @bind-Value=State.RememberMe.PassiveMode />
							</label>
						}
					</div>
					<label>
						Show Password:
						<InputCheckbox @bind-Value=ShowPass />
					</label>
				</div>
				@if (Connecting)
				{
					<div style="height:5vh;" class="spinner"></div>
				}
				else
				{
					<button type="submit">
						Login
					</button>
				}
			</form>
		}
		else
		{
			<div class="spinner"></div>
		}
		<div>
			<p style="color:red;">@Error</p>
		</div>
	</OverlayWindow>
}
@if (UploadRunning || DownloadRunning || State.UploadQue.Count > 0 || DownloadQue.Count > 0)
{
	<div style="overflow-y:auto; background-color:var(--bg-surface); overflow-x:hidden; padding:1vh; padding-right:2vh; z-index:2010; display:flex; flex-direction:column; position:fixed; right:2vh; bottom:2vh; width:25vw; height:20vh; min-width:250px; min-height:50px; box-shadow:2px 2px 10px rgba(0,0,0,0.5); border-radius:4px">
		<div style="position:absolute; top:-25px; right:-25px; width:50px; height:50px; background-color:var(--scrollbar-thumb); z-index:2011; transform: rotate(45deg); transform-origin: center; box-shadow:2px 2px 10px rgba(0,0,0,0.5);">
			<i @onclick:stopPropagation="true" @onclick="@(ClearQues)" class="fa-solid fa-xmark" title="Clear All Complete" style="transform: rotate(-45deg); position:absolute; top:27px; left:18px; width:20px; height:20px; cursor:pointer"></i>
		</div>

		@foreach (var item in State.UploadQue)
		{
			<div style="display:grid; grid-template-columns:10fr 10fr 80fr 10fr">
				<i class="fa-solid fa-arrow-turn-up" style="color:lightcoral; font-size:1rem; display:flex; align-items:center; justify-content:center;"></i>
				<i class="fa-regular fa-file" style="font-size:1.5rem; display:flex; align-items:center; justify-content:center;"></i>
				<h4 style="margin:0; text-wrap-mode:nowrap;text-overflow:ellipsis; overflow:hidden;" title="@item.Value.Name">@item.Value.Name</h4>
				<button title="@(item.Value.Proggress < 0 ? item.Value.Problem : $"{item.Value.Proggress.ToString("F2")}%")" @onclick="@(async () => { State.UploadQue.Remove(item.Key); if (State.UploadQue.Count == 0) { UploadRunning = false; await PreventClosing(UploadRunning); } })" style="padding:0; border:none; background-color:transparent; aspect-ratio:1; position:relative; border-radius:50%;">
					@if (item.Value.Proggress < 100)
					{
						<svg viewBox="0 0 100 100" style="width:100%; height:100%; position:absolute; top:0; left:0; transform:rotate(-90deg);">
							<!-- Background circle -->
							<circle cx="50" cy="50" r="45" stroke="#e0e0e0" stroke-width="12%" fill="none" />

							<!-- Progress circle -->
							<circle cx="50" cy="50" r="45"
									stroke="@(item.Value.Proggress < 0 ? "red" : "#4caf50")"
									stroke-width="12%"
									fill="none"
									stroke-dasharray="@((2 * Math.PI * 45))"
									stroke-dashoffset="@(item.Value.Proggress < 0 ? 0 : (1 - item.Value.Proggress / 100.0) * 2 * Math.PI * 45)" />
						</svg>
					}

					<i class="fa-solid @(item.Value.Proggress == 100 ? "fa-check" : "fa-xmark")"
					   style="display:flex; align-items:center; justify-content:center; width:100%; height:100%; position:absolute; top:0; left:0;"></i>
				</button>
			</div>
		}
		@foreach (var item in DownloadQue)
		{
			<div style="display:grid; grid-template-columns:10fr 10fr 80fr 10fr">
				<i class="fa-solid fa-arrow-turn-down" style="color:lightblue; font-size:1rem; display:flex; align-items:center; justify-content:center;"></i>
				<i class="fa-regular fa-file" style="font-size:1.5rem; display:flex; align-items:center; justify-content:center;"></i>
				<h4 style="margin:0; text-wrap-mode:nowrap;text-overflow:ellipsis; overflow:hidden;" title="@item.Value.Name">@item.Value.Name</h4>
				<button title="@(item.Value.Proggress < 0 ? item.Value.Problem : $"{item.Value.Proggress.ToString("F2")}%")" @onclick="@(async () => { DownloadQue.Remove(item.Key); if (DownloadQue.Count == 0 && State.UploadQue.Count == 0) { DownloadRunning = false; await PreventClosing(DownloadRunning); } })" style="padding:0; border:none; background-color:transparent; aspect-ratio:1; position:relative; border-radius:50%;">
					@if (item.Value.Proggress < 100)
					{
						<svg viewBox="0 0 100 100" style="width:100%; height:100%; position:absolute; top:0; left:0; transform:rotate(-90deg);">
							<!-- Background circle -->
							<circle cx="50" cy="50" r="45" stroke="#e0e0e0" stroke-width="12%" fill="none" />

							<!-- Progress circle -->
							<circle cx="50" cy="50" r="45"
									stroke="@(item.Value.Proggress < 0 ? "red" : "#4caf50")"
									stroke-width="12%"
									fill="none"
									stroke-dasharray="@((2 * Math.PI * 45))"
									stroke-dashoffset="@(item.Value.Proggress < 0 ? 0 : (1 - item.Value.Proggress / 100.0) * 2 * Math.PI * 45)" />
						</svg>
					}
					<i class="fa-solid @(item.Value.Proggress == 100 ? "fa-check" : "fa-xmark")"
					   style="display:flex; align-items:center; justify-content:center; width:100%; height:100%; position:absolute; top:0; left:0;"></i>
				</button>
			</div>
		}
	</div>
}
@if (CurrentDir != null)
{
	<div style="display:flex; flex-direction:row;justify-content:space-between">
		<div style="display:flex; flex-direction:row;">
			<button style="border:none; background:none; padding:0" @onclick="@(() => GetDirectory("/"))">
				<i class="fa-solid fa-house" style="font-size:1.5rem; display:flex; align-items:center"></i>
			</button>
			<h2 style="margin:0" class="no-select">/</h2>
			<div style="display:flex; flex-direction:row; overflow-x:auto; max-width:80vw">
				@for (int i = 0; i < CurrDirPath.Count; i++)
				{
					var d = i;
					<button style="border:none; background:none; padding:0" @onclick="@(() => { GetDirectory(CurrentDir.First.Substring(0, CurrentDir.First.IndexOf(CurrDirPath[d]) + CurrDirPath[d].Length)); })">
						<h2 style="margin:0; text-wrap-mode:nowrap;text-wrap:nowrap;">@CurrDirPath[i]</h2>
					</button>
					@if (CurrDirPath.Count != i + 1)
					{
						<h2 style="margin:0" class="no-select">/</h2>
					}
				}
			</div>
			@if (CurrDirPath.Count > 0)
			{
				<h2 style="margin:0" class="no-select">/</h2>
			}
		</div>
		<button style="border:none; background:none" @onclick="() => GetDirectory(null, true)"><i class="fa-solid fa-arrows-rotate" style="font-size:1.75rem; display:flex; align-items:center"></i></button>
	</div>
	<div style="overflow-y: auto; height:65vh; position: relative;" class="upload-container" @ref="containerRef">
		<div class="drag-overlay @(isDragging ? "visible" : "")">
			Drop files here
		</div>
		<div id="filesContainer" style="display:grid; grid-template-columns:30px 90fr;">
			@{
				int index = 0;
			}
			@foreach (var item in CurrentDir.Second.OrderBy(x => x.Type).ThenBy(x => x.Name))
			{
				string? v = GetFileIcon(item.Type);
				if (v == null)
				{
					<p style="font-size:7pt">@item.Type</p>
				}
				else
				{
					<i class="@v" style="font-size:1.5rem; display:flex; align-items:center; justify-content:center;"></i>
				}
				<div class="button-row @(State.Selected.Any(x => x != null) && State.Selected.Any(x => x.Equals(item)) ? "selected" : index % 2 == 1 ? "row-dark" : "row-light")" style="text-wrap-mode:nowrap;text-wrap:nowrap; display:grid; grid-template-columns:30fr 10fr 30fr 10fr;" @onclick="@((e) => FileAction(item, false, e.ShiftKey, e.CtrlKey))" @oncontextmenu="@(async (e) => { showMenu = true; xpx = $"{e.ClientX}px"; ypx = $"{e.ClientY}px"; await FileAction(item, true, e.ShiftKey, e.CtrlKey); })" @oncontextmenu:preventDefault @onclick:stopPropagation="true">
					@if (Renaming && State.Selected.Any(x => x != null) && State.Selected.Any(x => x.Equals(item)))
					{
						<input @ref="renameInput" @bind="NewName" @bind:event="oninput" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @onblur="() => { if (Renaming) SaveRename(); }" @onkeydown="HandleKeyDownRename" style="margin-right:10%;" />
					}
					else
					{
						<p style="font-weight:bold; margin-bottom:0; text-align:left; overflow-x:hidden; text-overflow:ellipsis;" title="@item.Name">@item.Name</p>
					}
					<p style="font-weight:bold; margin-right:20%; margin-bottom:0; text-align:left;@(item.Type == FileType.Directory ? " color:color-mix(in srgb, var(--text-main, white) 65%, var(--bg-main,black))" : "")" title="@(item.Type == FileType.Directory ? "Not the size of the content" : "")">@item.Size.ToClosestSize(State.Settings.TryGetValue("sizeunitformat", out var format) ? format : null)</p>
					<p style="font-weight:bold; overflow-x:hidden; text-overflow:ellipsis; margin-bottom:0; text-align:left;">@item.Modified.ToSaneString()</p>
					<p style="font-family: monospace; font-weight:bold; overflow-x:hidden; text-overflow:ellipsis; margin-bottom:0; text-align:left;">@Utils.GetUnixPermissions(item.Permissions)</p>
				</div>
				index++;
			}
		</div>
		@if (Loading)
		{
			<div style="display:flex; position:absolute; top:0; width:100%; height:100%; z-index:1000; background-color:rgba(0,0,0,0.1)">
				<div style="height:5vh" class="spinner"></div>
			</div>
		}
	</div>
}
else
{
	<div style="height:5vh" class="spinner"></div>
}
<div @onclick="@(() => { Error = ""; })">
	<p style="color:red;">@Error</p>
</div>
@if (State.Selected.Any(x => x != null) && showMenu)
{
	<div style="display:flex; flex-direction:column; position:absolute; left:@xpx; top:@ypx; min-width:100px; width:20%;" @onmouseleave="() => { showMenu = false; }" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true">
		@if (State.Selected.Count(x => x != null) > 1 || State.Selected.Count(x => x != null) == 1 && Utils.AllowedActions(State.Selected.Where(x => x != null).ElementAt(0), AllowedAction.Delete, text: out _))
		{
			<ConfirmButton class="button-context" DialogQuestion="@($"Are you sure you want to delete {string.Join(", ", State.Selected.Where(x => x != null).Select(x => x.Name))}?")" OnClick="Delete">
				Delete
			</ConfirmButton>
		}
		@if (State.Selected.Count(x => x != null) == 1 && Utils.AllowedActions(State.Selected.Where(x => x != null).ElementAt(0), AllowedAction.Edit, text: out State.EditModeText, State.Settings.TryGetValue("maxeditsize", out var maxedits) && int.TryParse(maxedits, out var maxe) ? maxe : 1048576))
		{
			<button class="button-context" @onclick="Edit" disabled="@State.UploadQue.Any(x => $"{State.Selected.Where(x => x != null).ElementAt(0).Name}.tmp" == x.Value.Name && x.Value.Proggress >= 0 && x.Value.Proggress < 100)">
				Edit
			</button>
		}
		@if (State.Selected.Count(x => x != null) > 1 || State.Selected.Count(x => x != null) == 1 && Utils.AllowedActions(State.Selected.Where(x => x != null).ElementAt(0), AllowedAction.ChangePermissions, text: out _) && (!State.Settings.TryGetValue("disablepermchange", out var allow) || !bool.TryParse(allow, out var val) || !val))
		{
			<button class="button-context" @onclick="ChangePerms">
				Permission Change
			</button>
		}
		@if (State.Selected.Count(x => x != null) == 1 && Utils.AllowedActions(State.Selected.Where(x => x != null).ElementAt(0), AllowedAction.Read, text: out State.EditModeText, State.Settings.TryGetValue("maxeditsize", out maxedits) && int.TryParse(maxedits, out maxe) ? maxe : 1048576))
		{
			<button class="button-context" @onclick="View" disabled="@State.UploadQue.Any(x => $"{State.Selected.Where(x => x != null).ElementAt(0).Name}.tmp" == x.Value.Name && x.Value.Proggress >= 0 && x.Value.Proggress < 100)">
				View
			</button>
		}
		@if (State.Selected.Count(x => x != null) > 1 || State.Selected.Count(x => x != null) == 1 && Utils.AllowedActions(State.Selected.Where(x => x != null).ElementAt(0), AllowedAction.Download, text: out _))
		{
			<button class="button-context" @onclick="Download">
				Download
			</button>
		}
		@if (State.Selected.Count(x => x != null) > 1 || State.Selected.Count(x => x != null) == 1 && Utils.AllowedActions(State.Selected.Where(x => x != null).ElementAt(0), AllowedAction.Rename, text: out _))
		{
			<button class="button-context" @onclick="Rename">
				Rename
			</button>
		}
	</div>
}
@if (CreateFolderOpen)
{
	<OverlayWindow XPercent="50" YPercent="40" OnClick="@(() => { CreateFolderOpen = false; })" OnKey="@((e) => { if (e.Key == "Enter") { CreateFolder(); CreateFolderOpen = false; } else if (e.Key == "Escape") { CreateFolderOpen = false; } })">
		<h3>New Folder Name:</h3>
		<input @ref="createFolderRef" @bind=CreateFolderName @bind:event="oninput" />
		<div style="display:flex;flex-direction:row;gap:20%;justify-content:center">
			<button class="btn-primary" style="padding:10%" @onclick="@(() => { CreateFolderOpen = false; CreateFolder(); })" tabindex="0">Create</button>
			<button class="secondary-button" style="padding:10%" @onclick="@(() => { CreateFolderOpen = false; })" tabindex="1">Cancel</button>
		</div>
	</OverlayWindow>
}
@if (CertWindowOpen)
{
	<OverlayWindow InnerClass="scrollable" InnerStyle="padding:10%;justify-content:initial" ZIndex="2060" XPercent="70" YPercent="80" OnKey="@((e) => { if (e.Key == "Enter") { CertWindowOpen = false; } else if (e.Key == "Escape") { CertWindowOpen = false; } })">
		<CertificateViewer Certificate="Certificate" />
		<div style="display:flex;flex-direction:row;gap:20%;justify-content:center">
			<button class="btn-primary" style="padding:10%" @onclick="@(async () => { CertWindowOpen = false; _certQuestion.TrySetResult(true); })" tabindex="0">Accept</button>
			<button class="secondary-button" style="padding:10%" @onclick="@(async () => { CertWindowOpen = false; _certQuestion.TrySetResult(false); })" tabindex="1">Cancel</button>
		</div>
		@if (State.Settings.TryGetValue("enablecerttrustfunction", out var val) && bool.TryParse(val, out var va) && va)
		{
			<div style="display:flex;flex-direction:row;justify-content:center">
				<label>
					Remember Certificate:
					<InputCheckbox @bind-Value=RememberCert @oninput="OnRememberCertChange" />
				</label>
			</div>
		}
	</OverlayWindow>
}
@if (PermsChangeOpen)
{
	<OverlayWindow XPercent="80" YPercent="60" OnClick="@(() => { PermsChangeOpen = false; })" OnKey="@((e) => { if (e.Key == "Enter") { ChangePerms(); PermsChangeOpen = false; } else if (e.Key == "Escape") { PermsChangeOpen = false; } })">
		<h3>New Permissions:</h3>
		<PermissionEditor @bind-Perm="PermsToChange" />
		<div style="display:flex;flex-direction:row;gap:20%;justify-content:center">
			<button class="btn-primary" style="padding:10%" @onclick="@(() => { ChangePerms(); PermsChangeOpen = false; })" tabindex="0">Create</button>
			<button class="secondary-button" style="padding:10%" @onclick="@(() => { PermsChangeOpen = false; })" tabindex="1">Cancel</button>
		</div>
	</OverlayWindow>
}
@if (ModWindowOpen)
{
	<OverlayWindow XPercent="90" YPercent="90" InnerStyle="gap:5vh">
		@if (State.EditModeText)
		{
			<select @bind="SelectedEncoding">
				@foreach (var enc in encodings.Keys)
				{
					<option value="@enc">@enc</option>
				}
			</select>

			<textarea readonly="@(!EditMode)" @bind="CurrentModFileContent" rows="20" cols="80"></textarea>
			@if (EditMode)
			{
				<button @onclick="EditConfirm">Save Changes</button>
			}
		}
		else
		{
			<img class="checkered-bg" src="@CurrentModFileContent" style="max-width:90vw; max-height:70vh; object-fit:contain;" />
		}
		<button @onclick="() => { EditMode = false; ModWindowOpen = false; }">@(EditMode ? "Cancel" : "Close")</button>
	</OverlayWindow>
}
@* <div>
	@foreach (var item in History)
	{
		<p>@item</p>
	}
</div> *@
@code
{
	[Parameter] public string? Path { get; set; }
	private bool LoggedIn = false;
	private bool Connecting = false;
	private bool UploadRunning = false;
	private bool DownloadRunning = false;
	private LoginJson LoginStuff { get; set; } = new();
	private bool ShowPass { get; set; } = false;
	private HubConnection? Hub { get; set; }
	private bool Loading { get; set; } = true;
	private string Error { get; set; } = "";
	private Pair<string, List<FtpItemDto>>? CurrentDir { get; set; } = null;
	private List<string> CurrDirPath { get; set; } = new();
	private LinkedList<string> History { get; set; } = new();
	private LinkedListNode<string>? CurrentHis { get; set; } = null;
	private bool isDragging = false;
	private bool dragEventsRegistered = false;
	private ElementReference containerRef;
	private DotNetObjectReference<Home>? dotnetRef;
	private Dictionary<string, UploadQueItemDto> DownloadQue = new();
	private CertificateDto? Certificate { get; set; } = null;
	private bool CertWindowOpen = false;
	private TaskCompletionSource<bool> _certQuestion;
	private int PermsToChange { get; set; }
	private bool PermsChangeOpen = false;
	private string SelectedEncoding
	{
		get => selectedEncoding;
		set
		{
			if (selectedEncoding != value)
			{
				selectedEncoding = value;
				CurrentModFileContent = encodings[value].GetString(CurrentModFileContentRaw);
				StateHasChanged();
			}
		}
	}

	private bool showMenu;
	private string xpx = "200px";
	private string ypx = "200px";
	private string dialogQuestion = "";
	private Action? dialogAction = null;
	private bool Renaming = false;
	private string NewName = "";
	private ElementReference renameInput;
	private bool shouldFocus;
	private bool _renameFristSelect = false;
	private ElementReference createFolderRef;
	private bool CreateFolderOpen = false;
	private string CreateFolderName = "";
	private bool _createFolderFirstSelect = false;
	private bool ModWindowOpen = false;
	private bool EditMode = false;
	private string CurrentModFile = "";
	private string CurrentModFileContent = "";
	private byte[] CurrentModFileContentRaw = [];
	private string selectedEncoding = "UTF-8";
	private Dictionary<string, Encoding> encodings = new()
	{
		{ "UTF-8", Encoding.UTF8 },
		{ "ASCII", Encoding.ASCII },
		{ "Unicode (UTF-16)", Encoding.Unicode },
		{ "UTF-32", Encoding.UTF32 }
	};
	private bool IsSwitchingDir = false;
	private bool RememberCert = false;

	private readonly SemaphoreSlim _upDownSemaphore = new(1, 1);

	//needs a fix for duplicate triggering cuz of blazor doing weird stuff with page refresh
	private async Task HandleFileSelected(InputFileChangeEventArgs e)
	{
		if (!HubGood()) return;

		var limit = 30;
		if (State.Settings.TryGetValue("maxfileuploadatonce", out var lim) && int.TryParse(lim, out limit)) { }
		isDragging = false;

		if (e.FileCount > limit)
		{
			Error = $"The number of files exceeded limit ({limit})";
			StateHasChanged();
			return;
		}

		UploadRunning = true;
		await PreventClosing(UploadRunning);
		StateHasChanged();
		var rofiles = e.GetMultipleFiles(limit);
		var files = new List<IBrowserFile>();

		var maxFileSize = 1024L * 1024 * 1024 * 500;
		if (State.Settings.TryGetValue("maxfileuploadsize", out var max) && long.TryParse(max, out var maxLim))
			maxFileSize = maxLim;

		foreach (var file in rofiles)
		{
			if (State.UploadQue.TryGetValue(file.Name, out var queueItem) && queueItem.Proggress == 100)
			{
				State.UploadQue.Remove(file.Name);
			}
			else if (State.UploadQue.ContainsKey(file.Name))
			{
				Error = $"File with the same name '{file.Name}' is already being uploaded";
				StateHasChanged();
				continue;
			}
			if (file.Size > maxFileSize)
			{
				Error = $"File '{file.Name}' is over the size limit ({maxFileSize.ToClosestSize(State.Settings.TryGetValue("sizeunitformat", out var format) ? format : null)})";
				StateHasChanged();
				continue;
			}

			if (!State.UploadQue.TryAdd(file.Name, new UploadQueItemDto(file.Name, 0))) continue;
			files.Add(file);
		}
		foreach (var file in files)
		{
			if (file.Size > 2 * 1024 * 1024) //2 MB
				GetDirectory(null, true);
			await UploadRoutine(file);
		}
		GetDirectory(null, true);
		await PreventClosing(false);
	}
	private async Task UploadRoutine(IBrowserFile file)
	{
		bool lockTaken = false;
		try
		{
			var chunkSize = 64 * 1024; // 64 KB chunks
			if (State.Settings.TryGetValue("uploadlimit", out var lim) && int.TryParse(lim, out var limit))
				chunkSize = limit;

			long offset = 0;
			var maxFileSize = 1024L * 1024 * 1024 * 500; // 500GB
			if (State.Settings.TryGetValue("maxfileuploadsize", out var max) && long.TryParse(max, out var maxLim))
				maxFileSize = maxLim;

			using var stream = file.OpenReadStream(maxFileSize);
			byte[] buffer = new byte[file.Size < chunkSize ? file.Size : chunkSize];

			if (!State.Settings.TryGetValue("simultaneousupdown", out var simul) || !bool.TryParse(simul, out var siml) || !siml)
			{
				await _upDownSemaphore.WaitAsync();
				lockTaken = true;
			}

			if (file.Size == 0)
			{
				if (!State.UploadQue.TryGetValue(file.Name, out var queueItem) || queueItem.Proggress < 0)
				{
					await Hub.InvokeAsync("UploadCancel", file.Name, true);
					goto skip;
				}
				var next = await Hub.InvokeAsync<string>("UploadChunk", new UploadMetadataDto() { Name = file.Name, Size = file.Size, UploadPath = CurrentDir.First }, new byte[0], offset);
				if (queueItem.Proggress >= 0)
					queueItem.Proggress = 100;
			}
			else
			{
				while (offset < file.Size)
				{
					if (!State.UploadQue.TryGetValue(file.Name, out var queueItem) || queueItem.Proggress < 0)
					{
						await Hub.InvokeAsync("UploadCancel", file.Name, true);
						goto skip;
					}
					int bytesRead = await stream.ReadAsync(buffer, 0, buffer.Length);
					if (bytesRead == 0) break;

					// Trim buffer for last chunk
					byte[] chunk = bytesRead == buffer.Length ? buffer : buffer[..bytesRead];

					// Send chunk to SignalR hub
					var next = await Hub.InvokeAsync<string>("UploadChunk", new UploadMetadataDto() { Name = file.Name, Size = file.Size, UploadPath = CurrentDir.First }, chunk, offset);

					offset += bytesRead;
					if (!long.TryParse(next, out var nexz) || offset != nexz)
					{
						queueItem.Problem = $"expected: {offset}, got: {next}";
						Error = $"expected: {offset}, got: {next}";
						await Hub.InvokeAsync("UploadCancel", file.Name, true); //for now cancel but later would be good to be able to resume the download
						goto skip;
					}
					if (queueItem.Proggress >= 0)
						queueItem.Proggress = (double)offset / file.Size * 100;
					StateHasChanged();
				}
			}

			// Notify server that file is complete
			await Hub.SendAsync("UploadFinish", file.Name);
		skip:;
		}
		finally
		{
			if (lockTaken)
				_upDownSemaphore.Release();

			StateHasChanged();
		}
	}
	private async void ClearQues()
	{
		var downloadKeysToRemove = DownloadQue
			.Where(kv => kv.Value.Proggress >= 100 || kv.Value.Proggress < 0)
			.Select(kv => kv.Key);
		foreach (var key in downloadKeysToRemove)
		{
			DownloadQue.Remove(key);
		}
		if (DownloadQue.Count == 0 && State.UploadQue.Count == 0)
		{
			DownloadRunning = false;
			await PreventClosing(DownloadRunning);
		}

		var uploadKeysToRemove = State.UploadQue
			.Where(kv => kv.Value.Proggress >= 100 || kv.Value.Proggress < 0)
			.Select(kv => kv.Key);
		foreach (var key in uploadKeysToRemove)
		{
			State.UploadQue.Remove(key);
		}
		if (State.UploadQue.Count == 0)
		{
			UploadRunning = false;
			await PreventClosing(UploadRunning);
		}
	}

	private async Task Download()
	{
		if (!HubGood() || !State.Selected.Any(x => x != null))
			return;

		var selection = State.Selected.Where(x => x != null).Select(x => new { x.Name, x.Size });
		foreach (var item in selection)
		{
			if (DownloadQue.TryGetValue(item.Name, out var queueItem) && queueItem.Proggress == 100)
			{
				DownloadQue.Remove(item.Name);
			}
			else if (DownloadQue.ContainsKey(item.Name))
			{
				Error = $"File with the same name '{item.Name}' is already being downloaded";
				StateHasChanged();
				continue;
			}

			DownloadRunning = true;
			DownloadQue.Add(item.Name, new(item.Name, 0));
		}
		StateHasChanged();
		foreach (var item in selection)
		{
			if (!DownloadQue.TryGetValue(item.Name, out var queueItem))
			{
				Error = $"Entry '{item.Name}' is missing";
				StateHasChanged();
				continue;
			}
			bool lockTaken = false;
			if (!State.Settings.TryGetValue("simultaneousupdown", out var simul) || !bool.TryParse(simul, out var siml) || !siml)
			{
				await _upDownSemaphore.WaitAsync();
				lockTaken = true;
			}
			var res = await Hub.InvokeAsync<string>("DownloadStart", item.Name, CurrentDir.First);

			if (!CheckReturn(res))
			{
				StateHasChanged();
				continue;
			}

			await JS.InvokeVoidAsync("helpers.startFileDownload", item.Name);
			await PreventClosing(DownloadRunning);
			long offset = 0;
			try
			{
				while (true)
				{
					if (!DownloadQue.TryGetValue(item.Name, out queueItem) || queueItem.Proggress < 0)
					{
						await Hub.InvokeAsync("DownloadCancel", item.Name);
						break;
					}
					var result = await Hub.InvokeAsync<Pair<byte[]?, string>>(
							"DownloadChunk", item.Name, offset);

					if (!CheckReturn(result.Second))
					{
						await Hub.InvokeAsync("DownloadCancel", item.Name);
						break;
					}

					if (result.Second.Contains("EOF"))
					{
						if (string.IsNullOrWhiteSpace(CurrentModFile) || CurrentModFile != item.Name)
							await JS.InvokeVoidAsync("helpers.finishFileDownload", item.Name);
						break;
					}

					if (result.First == null)
					{
						Error = "Received empty chunk unexpectedly";
						Console.WriteLine(Error);
						await Hub.InvokeAsync("DownloadCancel", item.Name);
						break;
					}


					var spl = result.Second.Split('|');
					if (!long.TryParse(spl[1].Trim(), out var nextOffset))
					{
						Error = "Invalid offset from server";
						Console.WriteLine(Error);
						await Hub.InvokeAsync("DownloadCancel", item.Name);
						break;
					}

					//Validation:
					if (nextOffset != offset + result.First.Length)
					{
						Error = $"Offset mismatch. Expected {offset + result.First.Length}, got {nextOffset}";
						Console.WriteLine(Error);
						await Hub.InvokeAsync("DownloadCancel", item.Name);
						break;
					}

					// Write chunk
					using var stream = new MemoryStream(result.First);
					var streamRef = new DotNetStreamReference(stream);
					// string base64Chunk = Convert.ToBase64String(result.First);
					await JS.InvokeVoidAsync("helpers.writeFileChunk", item.Name, streamRef);
					offset = nextOffset;

					if (item.Size > 0 && queueItem.Proggress >= 0)
						queueItem.Proggress = (double)offset / item.Size * 100;
					else if (queueItem.Proggress >= 0)
						queueItem.Proggress = 100d;

					StateHasChanged();
				}

				if (item.Size > 0 && queueItem.Proggress >= 0)
					queueItem.Proggress = (double)offset / item.Size * 100;
				else if (queueItem.Proggress >= 0)
					queueItem.Proggress = 100d;
				StateHasChanged();
			}
			catch (Exception e)
			{
				if (DownloadQue.TryGetValue(item.Name, out var qit))
				{
					qit.Proggress = -1;
					qit.Problem = e.Message;
				}
				Console.WriteLine(e.Message);
				if (State.Settings.TryGetValue("enabledebug", out var en) && bool.TryParse(en, out var val) && val)
					Console.WriteLine(e.StackTrace);
			}
			finally
			{
				await PreventClosing(false);
				DownloadRunning = false;
				if (string.IsNullOrWhiteSpace(CurrentModFile) || CurrentModFile != item.Name)
					await JS.InvokeVoidAsync("helpers.cleanupFileChunks", item.Name);
				StateHasChanged();
				if (lockTaken)
					_upDownSemaphore.Release();
			}
		}
	}
	private async Task OnRememberCertChange(ChangeEventArgs e)
	{
		bool newValue = (bool)e.Value;
		List<TrustedCertDto>? certs = null;
		try
		{
			certs = JsonSerializer.Deserialize<List<TrustedCertDto>>(await JS.InvokeAsync<string>("localStorage.getItem", "trustedCerts"));
		}
		catch { }
		if (certs == null && newValue && Certificate != null)
		{
			await JS.InvokeVoidAsync("localStorage.setItem", "trustedCerts", JsonSerializer.Serialize(new List<TrustedCertDto>() { new(Certificate.Subject, Certificate.Thumbprint, DateTime.Now) }));
		}
		else if (newValue && Certificate != null && certs != null && !certs.Any(x => x.Thumbprint == Certificate.Thumbprint))
		{
			certs.Add(new(Certificate.Subject, Certificate.Thumbprint, DateTime.Now));
			await JS.InvokeVoidAsync("localStorage.setItem", "trustedCerts", JsonSerializer.Serialize(certs));
		}
		else if (!newValue && certs != null && Certificate != null && certs.Any(x => x.Thumbprint == Certificate.Thumbprint))
		{
			var item = certs.FirstOrDefault(x => x.Thumbprint == Certificate.Thumbprint);
			if (item != null)
			{
				certs.Remove(item);
			}
			await JS.InvokeVoidAsync("localStorage.setItem", "trustedCerts", JsonSerializer.Serialize(certs));
		}
	}
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			if (dotnetRef == null)
			{
				dotnetRef = DotNetObjectReference.Create(this);
				await JS.InvokeVoidAsync("helpers.globalKeyboard.init", dotnetRef);
			}

			await StartHubConn();
			RememberSettingsDto? rememberMe = null;
			try
			{
				rememberMe = JsonSerializer.Deserialize<RememberSettingsDto>(await JS.InvokeAsync<string>("localStorage.getItem", "rememberMe"));
			}
			catch
			{
				if (State.Settings.TryGetValue("defaulttheme", out var deftheme))
				{
					State.RememberMe.Theme = deftheme;
				}
				Console.WriteLine("Error In Load RememberMe");
			}
			if (rememberMe != null)
			{
				State.RememberMe = rememberMe;
				LoginStuff.Host = State.RememberMe.Host;
				LoginStuff.Port = State.RememberMe.Port;
				LoginStuff.Username = State.RememberMe.Username;
				StateHasChanged();
			}
			Loading = false;
			StateHasChanged();
		}
		if (!dragEventsRegistered && CurrentDir != null)
		{
			dragEventsRegistered = true;
			await JS.InvokeVoidAsync(
				"helpers.registerDragEvents",
				containerRef,
				dotnetRef
			);
		}
		if (shouldFocus)
		{
			shouldFocus = false;
			await renameInput.FocusAsync();
			if (_renameFristSelect)
			{
				await JS.InvokeVoidAsync("helpers.selectInputText", renameInput);
				_renameFristSelect = false;
			}
		}
		if (CreateFolderOpen)
		{
			await createFolderRef.FocusAsync();
			if (_createFolderFirstSelect)
			{
				_createFolderFirstSelect = false;
				await JS.InvokeVoidAsync("helpers.selectInputText", createFolderRef);
			}
		}
		await base.OnAfterRenderAsync(firstRender);
	}
	private async void Delete()
	{
		if (!HubGood() || !State.Selected.Any(x => x != null)) return;
		foreach (var item in State.Selected)
		{
			if (item == null) continue;
			var res = await Hub.InvokeAsync<string>("Delete", item.Name);
			CheckReturn(res);
		}
		GetDirectory(null, true);
	}
	private async Task SaveRememberMe()
	{
		await JS.InvokeVoidAsync("localStorage.setItem", "rememberMe", JsonSerializer.Serialize(State.RememberMe));
	}
	private async void GetDirectory(string? path = null, bool ignoreHistory = false, bool frombrowser = false)
	{
		if (!HubGood()) return;
		Error = "";
		Loading = true;
		IsSwitchingDir = true;
		State.Selected.Clear();
		State.DirectoryLoading = true;
		State.NotifyStateChanged();
		var dat = "";
		try
		{
			if (string.IsNullOrWhiteSpace(path))
			{
				dat = await Hub.InvokeAsync<string>("GetCurrentDirectory");
				CurrentDir = JsonSerializer.Deserialize<Pair<string, List<FtpItemDto>>>(dat);
			}
			else if (await Hub.InvokeAsync<bool>("GoTo", path))
			{
				dat = await Hub.InvokeAsync<string>("GetCurrentDirectory");
				CurrentDir = JsonSerializer.Deserialize<Pair<string, List<FtpItemDto>>>(dat);
			}
			else
			{
				GetDirectory();
				Error = "Directory Navigation Error";
			}
		}
		catch (Exception e)
		{
			var spl = dat.Split('|');
			Error = spl[0];
			foreach (var item in spl)
			{
				Console.WriteLine(item);
			}
			Console.WriteLine(e.Message);
			if (State.Settings.TryGetValue("enabledebug", out var en) && bool.TryParse(en, out var val) && val)
				Console.WriteLine(e.StackTrace);
			return;
		}

		if (CurrentDir != null)
		{
			var p = CurrentDir.First.Split('/');
			CurrDirPath = new();
			if (p.Where(x => !string.IsNullOrWhiteSpace(x)).Count() <= 0)
			{
				CurrDirPath = new();
			}
			else
			{
				CurrDirPath = p.Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
			}

			if (!ignoreHistory && !frombrowser && (History.Count == 0 || History.Last.Value != CurrentDir.First))
			{
				if (CurrentHis != null)
				{
					var node = CurrentHis.Next;
					while (node != null)
					{
						var next = node.Next;
						History.Remove(node);
						node = next;
					}
					History.AddAfter(CurrentHis, CurrentDir.First);
					CurrentHis = CurrentHis.Next;
				}
				else
				{
					History.AddLast(CurrentDir.First);
					CurrentHis = History.Last;
				}
			}

			// Navigate without reloading
			if (!frombrowser)
			{
				var uri = new Uri(Nav.Uri);
				var origin = $"{uri.Scheme}://{uri.Host}{(!uri.IsDefaultPort ? $":{uri.Port}" : "")}";
				var newUrl = $"{origin}/{CurrentHis.Value.TrimStart('/')}";
				Nav.NavigateTo(newUrl, replace: false);
			}

			dragEventsRegistered = false;
			await OnAfterRenderAsync(true);
		}
		Loading = false;
		State.DirectoryLoading = false;
		IsSwitchingDir = false;
		StateHasChanged();
	}
	private string? GetFileIcon(FileType type)
	{
		switch (type)
		{
			case FileType.Directory:
				return "fa-solid fa-folder";
			case FileType.File:
				return "fa-regular fa-file";
			default:
				return null;
		}
	}
	private async Task FileAction(FtpItemDto item, bool rightclick, bool shift, bool ctrl)
	{
		if (item.Type == FileType.Directory && !rightclick && !shift && !ctrl)
		{
			GetDirectory($"{CurrentDir.First}/{item.Name}");
		}
		else if (((!shift && !ctrl) || State.Selected.Count(x => x != null) <= 0) && (State.Selected.Count(x => x != null) > 1 || !State.Selected.Where(x => x != null).Any(x => x.Equals(item))))
		{
			State.Selected.Clear();
			State.Selected.Add(item);
			State.NotifyStateChanged();
		}
		else if (State.Selected.Count(x => x != null) == 1 && State.Selected.Where(x => x != null).Any(x => x.Equals(item)))
		{
			State.Selected.Clear();
			State.NotifyStateChanged();
		}
		else if (State.Selected.Count(x => x != null) > 0 && shift)
		{
			var ordered = CurrentDir.Second.OrderBy(x => x.Type).ThenBy(x => x.Name).ToList();
			var ind = ordered.IndexOf(State.Selected.First(x => x != null));
			var trgind = ordered.IndexOf(item);
			if (ind == -1 || trgind == -1)
			{
				Console.WriteLine($"Couldn't find {State.Selected.First(x => x != null).Name}({ind}) or {item.Name}({trgind}) in selected values");
				return;
			}
			var from = Math.Min(ind, trgind);
			var to = Math.Max(ind, trgind);

			var rangeItems = ordered
				.Skip(from)
				.Take(to + 1 - from)
				.ToList();

			State.Selected.Clear();
			foreach (var file in rangeItems)
			{
				State.Selected.Add(file);
			}

			State.NotifyStateChanged();
		}
		else if (State.Selected.Count(x => x != null) > 0 && ctrl)
		{
			if (CurrentDir.Second.Any(x => x != null && x.Equals(item)))
			{
				if (State.Selected.Any(x => x != null && x.Equals(item)))
				{
					State.Selected.RemoveAll(x => x != null && x.Equals(item));
				}
				else
				{
					State.Selected.Add(item);
				}
			}
			State.NotifyStateChanged();
		}
	}
	private async Task ClearHubConn()
	{
		if (Hub != null)
		{
			try
			{
				await Hub.StopAsync();
				await Hub.DisposeAsync();
				Hub = null;
			}
			catch { }
		}
	}
	private async Task StartHubConn()
	{
		if (Hub != null && Hub.State != HubConnectionState.Connected)
		{
			await ClearHubConn();
		}
		if (Hub == null)
		{
			var baseUrl = Env.GetValue<string>("ApiBaseUrl");
			Hub = new HubConnectionBuilder()
				.WithUrl($"{baseUrl}ftphub")
				.WithAutomaticReconnect()
				.Build();
			await InitHubStuff();
			await Hub.StartAsync();
			Hub.Reconnecting += (e) => InitHubStuff();
		}
	}
	private async Task InitHubStuff()
	{
		if (Hub == null) return;
		Hub.On<List<Pair>>("ReceiveInitData", async data =>
			{
				State.Settings = data.ToDictionary(y => y.Name, x => x.Value);
				StateHasChanged();

				//try reconnect with current Settings if exist
				if (!string.IsNullOrWhiteSpace(LoginStuff.Username) && !string.IsNullOrWhiteSpace(LoginStuff.Host) && !string.IsNullOrWhiteSpace(LoginStuff.Password))
				{
					var res = await Hub.InvokeAsync<string>("InitFtp", LoginStuff);
					if (CheckReturn(res))
					{
						LoggedIn = true;
						GetDirectory();
					}
				}
			});
		Hub.On<Pair>("ForceUploadCancel", async data =>
			{
				if (State.UploadQue.TryGetValue(data.Name, out var que))
				{
					que.Proggress = -1;
					que.Problem = data.Value;
				}
			});
		Hub.On<Pair>("ForceDownloadCancel", async data =>
			{
				if (DownloadQue.TryGetValue(data.Name, out var que))
				{
					que.Proggress = -1;
					que.Problem = data.Value;
				}
			});
	}
	private bool HubGood()
	{
		if (Hub == null || Hub.State != HubConnectionState.Connected)
			return false;

		return true;
	}
	/// <summary>
	/// returns true if first part is bool true, false otherwise and sets error message to second part if exist
	/// </summary>
	/// <param name="res"></param>
	/// <returns></returns>
	private bool CheckReturn(string res)
	{
		var spl = res.Split('|');
		if (!bool.TryParse(spl[0], out var ok) || !ok)
		{
			Error = spl.Length > 1 ? spl[1].Trim() : "Unknown error";
			HandleStateChange();
			Console.WriteLine(Error);
			if ((spl.Length > 2 && State.Settings.TryGetValue("enabledebug", out var en) && bool.TryParse(en, out var val) && val) || spl.Length > 2)
			{
				Console.WriteLine(spl[2].Trim());
			}
			return false;
		}
		return true;
	}

<div style="display:@(DialogOpen ? "flex" : "none"); z-index:2010; background-color:rgba(0,0,0,0.5); position:fixed; top:0; left:0; width:100%; height:100%;justify-content:center;align-items:center;" @onclick=@(() => { DialogOpen = false; StateHasChanged(); })>
    <div style="height:20%; width:50%; border-radius:10px; display:flex;justify-content:center;align-items:center; flex-direction:column;">
        <h3 style="color:white">@(string.IsNullOrWhiteSpace(DialogQuestion) ? "Are you sure?" : DialogQuestion)</h3>
        <div style="display:flex;flex-direction:row;gap:20%;justify-content:center">
            <button class="btn-primary" style="padding:10%; color:white;" onclick="@(() => { DialogOpen = false; if (OnClick != null) OnClick.Invoke(); })">Confirm</button>
            <button class="secondary-button" style="padding:10%" onclick="@(() => { DialogOpen = false; StateHasChanged(); })">Cancel</button>
        </div>
    </div>
</div>
<button @attributes="AdditionalAttributes" onclick="@(() => { DialogOpen = true; StateHasChanged(); })">@ChildContent</button>
@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public Action? OnClick { get; set; } = null;
    [Parameter] public string DialogQuestion { get; set; } = null;
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool DialogOpen = false;
}

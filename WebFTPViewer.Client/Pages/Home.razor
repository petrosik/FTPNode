    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (IsSwitchingDir)
        {
            IsSwitchingDir = false;
            return;
        }
        if (!HubGood() || !LoggedIn)
            return;

        var relativePath = $"/{Nav.ToBaseRelativePath(e.Location)}";

        var next = CurrentHis?.Next;
        var prev = CurrentHis?.Previous;
        if (!string.IsNullOrWhiteSpace(next?.Value) && next.Value == relativePath)
        {
            CurrentHis = next;
        }
        else if (!string.IsNullOrWhiteSpace(prev?.Value) && prev.Value == relativePath)
        {
            CurrentHis = prev;
        }
        GetDirectory(relativePath, frombrowser: true);
    }

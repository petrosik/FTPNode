        State.BackClicked -= Back;
        State.ForwardClicked -= Forward;
        State.LogoutClicked -= Logout;
        State.UploadClicked -= Upload;
        State.DeleteClicked -= Delete;
        State.DownloadClicked -= Download;
        State.RenameClicked -= Rename;
        State.ViewClicked -= View;
        State.EditClicked -= Edit;
        State.CreateFolderClicked -= CreateFolderDialog;
        State.PermChangeClicked -= ChangePerms;
        State.OnChange -= HandleStateChange;

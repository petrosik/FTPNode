@using System.Net
@using Shared
@using Petrosik.Http
@using Microsoft.AspNetCore.SignalR.Client;
@using Microsoft.Extensions.Configuration;
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting;
@using System.Text.Json;
@page "/"
@inject HttpClient Http
@inject IConfiguration Env
@inject IJSRuntime JS
@inject AppState State
@rendermode InteractiveWebAssembly

@if (!LoggedIn)
{
	<div style="width:100vw; height:100vh; background-color:rgba(0,0,0,0.3	); position:absolute; top:0; left:0; z-index:2050; display:flex; justify-content:center; align-items:center">
		<div style="background-color:white; border-radius:5px; min-width: 95%;width:65%; height:65%; display:flex; align-items:center;flex-direction:column">
			<h2 style="font-weight:bold; padding:1%; height:auto; margin:0;">Login</h2>
			@if (!Loading)
			{
				<form @onsubmit="OnLogin" style="display:flex;flex-direction:column; align-items:center; gap:2vh; height:auto; margin:2%">
					<div style="display:grid; grid-template-columns:10fr 90fr; align-items:center; gap:1%;">
						<p style="margin:0">
							Host:
						</p>
						<InputText @bind-value=LoginStuff.Host placeholder="10.0.0.0 or example.com" />
						<p style="margin:0">
							Port:
						</p>
						<InputNumber @bind-value=LoginStuff.Port placeholder="21" />
						<p style="margin:0">
							Username:
						</p>
						<InputText @bind-value=LoginStuff.Username />
						<p style="margin:0">
							Password:
						</p>
						<InputText @bind-Value="LoginStuff.Password" type="@(ShowPass ? "text" : "password")" />
					</div>
					<div style="display:flex; flex-direction:row; justify-content:space-between; gap:10vw">
						<div style="display:flex; flex-direction:column; justify-content:space-between;gap:2vh">
							<label>
								Remember Me:
								<InputCheckbox @bind-Value=RememberMe.RememberMe @oninput=OnRememberChange />
							</label>
							<label>
								Passive Mode:
								<InputCheckbox @bind-Value=RememberMe.PassiveMode />
							</label>
						</div>
						<label>
							Show Password:
							<InputCheckbox @bind-Value=ShowPass />
						</label>
					</div>
					@if (Connecting)
					{
						<div style="height:5vh;" class="spinner"></div>
					}
					else
					{
						<button type="submit">
							Login
						</button>
					}
				</form>
			}
			else
			{
				<div class="spinner"></div>
			}
			<div>
				<p style="color:red;">@Error</p>
			</div>
		</div>
	</div>
}
@if (CurrentDir.HasValue)
{
	<div style="display:flex; flex-direction:row;justify-content:space-between">
		<div style="display:flex; flex-direction:row;">
			<button style="border:none; background:none; padding:0" @onclick="@(() => GetDirectory("/"))">
				<i class="fa-solid fa-house" style="font-size:1.5rem; display:flex; align-items:center"></i>
			</button>
			<h2 style="margin:0" class="no-select">/</h2>
			<div style="display:flex; flex-direction:row; overflow-x:auto; max-width:80vw">
				@for (int i = 0; i < CurrDirPath.Count; i++)
				{
					var d = i;
					<button style="border:none; background:none; padding:0" @onclick="@(() => { GetDirectory(CurrentDir.Value.Key.Substring(0, CurrentDir.Value.Key.IndexOf(CurrDirPath[d]) + CurrDirPath[d].Length)); })">
						<h2 style="margin:0; text-wrap-mode:nowrap;text-wrap:nowrap;">@CurrDirPath[i]</h2>
					</button>
					@if (CurrDirPath.Count != i + 1)
					{
						<h2 style="margin:0" class="no-select">/</h2>
					}
				}
			</div>
			@if (CurrDirPath.Count > 0)
			{
				<h2 style="margin:0" class="no-select">/</h2>
			}
		</div>
		<button style="border:none; background:none" @onclick="() => GetDirectory(null, true)"><i class="fa-solid fa-arrows-rotate" style="font-size:1.75rem; display:flex; align-items:center"></i></button>
	</div>
	@if (!Loading)
	{
		<div style="overflow-y: auto; height:65vh; position: relative;" class="upload-container" @ref="containerRef">
			<div class="drag-overlay @(isDragging ? "visible" : "")">
				Drop files here
			</div>
			<InputFile id="fileInput" class="file-input-overlay" OnChange="HandleFileSelected" />
			<div style="display:grid; grid-template-columns:30px 90fr;">
				@foreach (var item in CurrentDir.Value.Value.OrderBy(x => x.Type).ThenBy(x => x.Name))
				{
					string? v = GetFileIcon(item.Type);
					if (v == null)
					{
						<p style="font-size:7pt">@item.Type</p>
					}
					else
					{
						<i class="@v" style="font-size:1.5rem; display:flex; align-items:center; justify-content:center;"></i>
					}
					<button style=" text-wrap-mode:nowrap;text-wrap:nowrap; display:grid; grid-template-columns:30fr 30fr 30fr;" @onclick="@(() => FileAction(item))">
						<p style="font-weight:bold; margin-bottom:0; text-align:left; overflow-x:hidden; text-overflow:ellipsis;" title="@item.Name">@item.Name</p>
						<p style="font-weight:bold; margin-bottom:0; text-align:left;@(item.Type == FileType.Directory ? " color: darkgray" : "")" title="@(item.Type == FileType.Directory ?"Not the size of the content":"")">@item.Size.ToClosestSize()</p>
						<p style="font-weight:bold; margin-bottom:0; text-align:left;">@item.Permissions</p>
					</button>

				}
			</div>
		</div>
	}
	else
	{
		<div style="height:5vh" class="spinner"></div>
	}
}
else
{
	<div style="height:5vh" class="spinner"></div>
}
<div>
	<p style="color:red;">@Error</p>
</div>
@code
{
	private bool LoggedIn = false;
	private bool Connecting = false;
	private LoginJson LoginStuff { get; set; } = new();
	private RememberMeDto RememberMe { get; set; } = new();
	private bool ShowPass { get; set; } = false;
	private HubConnection? Hub { get; set; }
	private bool Loading { get; set; } = true;
	private string Error { get; set; } = "";
	private KeyValuePair<string, List<FtpItemDto>>? CurrentDir { get; set; } = null;
	private List<string> CurrDirPath { get; set; } = null;
	private LinkedList<string> History { get; set; } = new();
	private LinkedListNode<string>? CurrentHis { get; set; } = null;
	private bool isDragging = false;
	private bool dragEventsRegistered = false;
	private ElementReference containerRef;
	private DotNetObjectReference<Home>? dotnetRef;

	private async Task HandleFileSelected(InputFileChangeEventArgs e)
	{
		isDragging = false;
		foreach (var file in e.GetMultipleFiles())
		{
			Console.WriteLine($"{file.Name} ({file.Size} bytes)");
			var chunkSize = 64 * 1024; // 64 KB chunks
			long offset = 0;

			using var stream = file.OpenReadStream(); // 500MB max maxAllowedSize: 1024 * 1024 * 500
			byte[] buffer = new byte[chunkSize];

			while (offset < file.Size)
			{
				int bytesRead = await stream.ReadAsync(buffer, 0, buffer.Length);
				if (bytesRead == 0) break;

				// Trim buffer for last chunk
				byte[] chunk = bytesRead == buffer.Length ? buffer : buffer[..bytesRead];

				// Send chunk to SignalR hub
				await Hub.InvokeAsync<string>("UploadChunk", file.Name, chunk, offset);

				offset += bytesRead;
			}

			// Notify server that file is complete
			await Hub.SendAsync("UploadFinish", new UploadMetadataDto() { Name = file.Name, Size = file.Size, UploadPath = CurrentDir.Value.Key});
		}
	}
	[JSInvokable]
	public void ShowOverlay()
	{
		isDragging = true;
		StateHasChanged();
	}

	[JSInvokable]
	public void HideOverlay()
	{
		isDragging = false;
		StateHasChanged();
	}
	private async Task OnLogin()
	{
		Error = "";
		Connecting = true;
		if (RememberMe.RememberMe)
		{
			await SaveRememberMe();
		}
		await ClearHubConn();
		var baseUrl = Env.GetValue<string>("ApiBaseUrl");
		Hub = new HubConnectionBuilder()
			.WithUrl($"{baseUrl}ftphub") // replace with your hub URL
			.WithAutomaticReconnect()                 // optional: auto-reconnect
			.Build();
		await Hub.StartAsync();
		if (Hub.State == HubConnectionState.Connected)
		{
			var res = await Hub.InvokeAsync<string>("InitFtp", LoginStuff);
			if (!bool.TryParse(res, out _))
			{
				Error = res.Substring(0, res.IndexOf('|')).Trim();
				Console.WriteLine(res.Substring(res.IndexOf('|') + 1).Trim());
			}
			else
			{
				LoggedIn = true;
				GetDirectory();
			}
		}
		Connecting = false;
	}
	protected override void OnInitialized()
	{
		State.BackClicked += Back;
		State.ForwardClicked += Forward;
		State.LogoutClicked += Logout;
		State.UploadClicked += Upload;
		base.OnInitialized();
	}
	private void Back()
	{
		var prev = CurrentHis?.Previous;
		if (string.IsNullOrWhiteSpace(prev?.Value))
		{
			Error = "Error while going back";
			StateHasChanged();
			return;
		}
		CurrentHis = prev;
		GetDirectory(prev.Value, true);
	}
	private void Forward()
	{
		var next = CurrentHis?.Next;
		if (string.IsNullOrWhiteSpace(next?.Value))
		{
			Error = "Error while going forward";
			StateHasChanged();
			return;
		}
		CurrentHis = next;
		GetDirectory(next.Value, true);
	}
	private async void Logout()
	{
		await ClearHubConn();
		LoggedIn = false;
		Loading = true;
		CurrentDir = null;
		dragEventsRegistered = false;
		await OnAfterRenderAsync(true);
		StateHasChanged();
	}
	private async void Upload()
	{
		await JS.InvokeVoidAsync("helpers.openFileDialog", "fileInput");
	}
	private async Task OnRememberChange(ChangeEventArgs e)
	{
		bool newValue = (bool)e.Value;
		RememberMe.RememberMe = newValue;
		if (!newValue) { await JS.InvokeVoidAsync("localStorage.removeItem", "rememberMe"); return; }
		await SaveRememberMe();
	}
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			Loading = false;
			RememberMeDto? rememberMe = null;
			try
			{
				rememberMe = JsonSerializer.Deserialize<RememberMeDto>(await JS.InvokeAsync<string>("localStorage.getItem", "rememberMe"));
			}
			catch
			{
				Console.WriteLine("Error In Load RememberMe");
				return;
			}
			if (rememberMe != null)
			{
				RememberMe = rememberMe;
				LoginStuff.Host = RememberMe.Host;
				LoginStuff.Port = RememberMe.Port;
				LoginStuff.Username = RememberMe.Username;
				StateHasChanged();
			}
		}
		if (!dragEventsRegistered && CurrentDir.HasValue)
		{
			dragEventsRegistered = true;
			dotnetRef = DotNetObjectReference.Create(this);
			await JS.InvokeVoidAsync(
				"helpers.registerDragEvents",
				containerRef,
				dotnetRef
			);
		}
		await base.OnAfterRenderAsync(firstRender);
	}
	private async Task SaveRememberMe()
	{
		RememberMe.Host = LoginStuff.Host;
		RememberMe.Port = LoginStuff.Port;
		RememberMe.Username = LoginStuff.Username;
		RememberMe.PassiveMode = LoginStuff.PassiveMode;
		await JS.InvokeVoidAsync("localStorage.setItem", "rememberMe", JsonSerializer.Serialize(RememberMe));
	}
	private async void GetDirectory(string? path = null, bool ignoreHistory = false)
	{
		Error = "";
		Loading = true;
		StateHasChanged();
		if (string.IsNullOrWhiteSpace(path))
		{
			CurrentDir = JsonSerializer.Deserialize<KeyValuePair<string, List<FtpItemDto>>>(await Hub.InvokeAsync<string>("GetCurrentDirectory"));
		}
		else if (Hub != null && await Hub.InvokeAsync<bool>("GoTo", path))
		{
			CurrentDir = JsonSerializer.Deserialize<KeyValuePair<string, List<FtpItemDto>>>(await Hub.InvokeAsync<string>("GetCurrentDirectory"));
		}
		else
		{
			Error = "Directory Switch Error";
		}

		if (CurrentDir.HasValue)
		{
			var p = CurrentDir.Value.Key.Split('/');
			CurrDirPath = new();
			if (p.Where(x => !string.IsNullOrWhiteSpace(x)).Count() <= 0)
			{
				CurrDirPath = new();
			}
			else
			{
				CurrDirPath = p.Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
			}

			if (!ignoreHistory && (History.Count == 0 || History.Last.Value != CurrentDir.Value.Key))
			{
				History.AddLast(CurrentDir.Value.Key);
				CurrentHis = History.Last;
			}
		}
		Loading = false;
		StateHasChanged();
	}
	private string? GetFileIcon(FileType type)
	{
		switch (type)
		{
			case FileType.Directory:
				return "fa-solid fa-folder";
			case FileType.File:
				return "fa-regular fa-file";
			default:
				return null;
		}
	}
	private async Task FileAction(FtpItemDto item)
	{
		switch (item.Type)
		{
			case FileType.Directory:
				GetDirectory($"{CurrentDir.Value.Key}/{item.Name}");
				return;
			default:
				return;
		}
	}
	private async Task ClearHubConn()
	{
		if (Hub != null)
		{
			try
			{
				await Hub.StopAsync();
				await Hub.DisposeAsync();
			}
			catch { }
		}
	}
	public void Dispose()
	{
		State.BackClicked -= Back;
		State.ForwardClicked -= Forward;
		State.LogoutClicked -= Logout;
		State.UploadClicked -= Upload;

		ClearHubConn();
	}
}
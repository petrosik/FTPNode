    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await StartHubConn();
            RememberMeDto? rememberMe = null;
            try
            {
                rememberMe = JsonSerializer.Deserialize<RememberMeDto>(await JS.InvokeAsync<string>("localStorage.getItem", "rememberMe"));
            }
            catch
            {
                Console.WriteLine("Error In Load RememberMe");
            }
            if (rememberMe != null)
            {
                RememberMe = rememberMe;
                LoginStuff.Host = RememberMe.Host;
                LoginStuff.Port = RememberMe.Port;
                LoginStuff.Username = RememberMe.Username;
                StateHasChanged();
            }
            Loading = false;
            StateHasChanged();
        }
        if (!dragEventsRegistered && CurrentDir != null)
        {
            dragEventsRegistered = true;
            dotnetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync(
                "helpers.registerDragEvents",
                containerRef,
                dotnetRef
            );
        }
        if (shouldFocus)
        {
            shouldFocus = false;
            await renameInput.FocusAsync();
            if (_renameFristSelect)
            {
                await JS.InvokeVoidAsync("helpers.selectInputText", renameInput);
                _renameFristSelect = false;
            }
        }
        if (CreateFolderOpen)
        {
            await createFolderRef.FocusAsync();
            if (_createFolderFirstSelect)
            {
                _createFolderFirstSelect = false;
                await JS.InvokeVoidAsync("helpers.selectInputText", createFolderRef);
            }
        }
        await base.OnAfterRenderAsync(firstRender);
    }

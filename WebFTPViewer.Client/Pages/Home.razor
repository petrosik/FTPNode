    private async Task OnLogin()
    {
        Error = "";
        Connecting = true;
        if (RememberMe.RememberMe)
        {
            await SaveRememberMe();
        }
        await StartHubConn();
        if (HubGood())
        {
            if (State.Settings.TryGetValue("host", out var host))
                LoginStuff.Host = host;
            if (State.Settings.TryGetValue("port", out var port) && int.TryParse(port, out var pp))
                LoginStuff.Port = pp;
            if (State.Settings.TryGetValue("passivemode", out var pass) && bool.TryParse(pass, out var pas))
                LoginStuff.PassiveMode = pas;


            var cert = await Hub.InvokeAsync<CertificateDto?>("GetCert", LoginStuff.Host, LoginStuff.Port);
            if (cert != null)
            {
                var tcs = new TaskCompletionSource<bool>(TaskCreationOptions.RunContinuationsAsynchronously);
                CertWindowOpen = true;
                Certificate = cert;
                _certQuestion = tcs;
                StateHasChanged();
                LoginStuff.AcceptCert = await tcs.Task;
                LoginStuff.OriginalCertThumbprint = cert.Thumbprint;
            }
            if (!State.Settings.TryGetValue("publickey", out var pubkey))
            {
                Error = "Public key not set in settings, refusing to connect for security reasons";
                StateHasChanged();
                return;
            }
            //encrypt password with RSA
            string encryptedPassword = await JS.InvokeAsync<string>("helpers.encryptPasswordWithPublicKey", LoginStuff.Password, pubkey);
            LoginStuff.Password = encryptedPassword;

            var res = await Hub.InvokeAsync<string>("InitFtp", LoginStuff);
            if (CheckReturn(res))
            {
                LoggedIn = true;
                GetDirectory(Path);
            }
        }
        Connecting = false;
    }

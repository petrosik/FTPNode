    private async Task ClearHubConn()
    {
        if (Hub != null)
        {
            try
            {
                await Hub.StopAsync();
                await Hub.DisposeAsync();
                Hub = null;
            }
            catch { }
        }
    }
    private async Task StartHubConn()
    {
        if (Hub != null && Hub.State != HubConnectionState.Connected)
        {
            await ClearHubConn();
        }
        if (Hub == null)
        {
            var baseUrl = Env.GetValue<string>("ApiBaseUrl");
            Hub = new HubConnectionBuilder()
                .WithUrl($"{baseUrl}ftphub")
                .WithAutomaticReconnect()
                .Build();
            await InitHubStuff();
            await Hub.StartAsync();
            Hub.Reconnecting += (e) => InitHubStuff();
        }
    }
    private async Task InitHubStuff()
    {
        if (Hub == null) return;
        Hub.On<List<Pair>>("ReceiveInitData", async data =>
            {
                State.Settings = data.ToDictionary(y => y.Name, x => x.Value);
                StateHasChanged();

                //try reconnect with current Settings if exist
                if (!string.IsNullOrWhiteSpace(LoginStuff.Username) && !string.IsNullOrWhiteSpace(LoginStuff.Host) && !string.IsNullOrWhiteSpace(LoginStuff.Password))
                {
                    var res = await Hub.InvokeAsync<string>("InitFtp", LoginStuff);
                    if (CheckReturn(res))
                    {
                        LoggedIn = true;
                        GetDirectory();
                    }
                }
            });
        Hub.On<Pair>("ForceUploadCancel", async data =>
            {
                if (UploadQue.TryGetValue(data.Name, out var que))
                {
                    que.Proggress = -1;
                    que.Problem = data.Value;
                }
            });
        Hub.On<Pair>("ForceDownloadCancel", async data =>
            {
                if (DownloadQue.TryGetValue(data.Name, out var que))
                {
                    que.Proggress = -1;
                    que.Problem = data.Value;
                }
            });
    }
    private bool HubGood()
    {
        if (Hub == null || Hub.State != HubConnectionState.Connected)
            return false;

        return true;
    }
    /// <summary>
    /// returns true if first part is bool true, false otherwise and sets error message to second part if exist
    /// </summary>
    /// <param name="res"></param>
    /// <returns></returns>
    private bool CheckReturn(string res)
    {
        var spl = res.Split('|');
        if (!bool.TryParse(spl[0], out var ok) || !ok)
        {
            Error = spl.Length > 1 ? spl[1].Trim() : "Unknown error";
            HandleStateChange();
            Console.WriteLine(Error);
            if ((spl.Length > 2 && State.Settings.TryGetValue("enabledebug", out var en) && bool.TryParse(en, out var val) && val) || spl.Length > 2)
            {
                Console.WriteLine(spl[2].Trim());
            }
            return false;
        }
        return true;
    }
